# ── Database (Postgres / Supabase) ───────────────────────────────────────────
# App/runtime connection — Supabase TRANSACTION pooler (:6543), scales for serverless:
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"
# Migrations connection — Supabase SESSION pooler (:5432), needed by Prisma Migrate.
# Only used by `prisma migrate`/`db` commands and the Vercel build; not at runtime.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Auth.js (do NOT hard-code secrets; leave blank until needed) ─────────────
# Required once accounts are enabled. Generate: `openssl rand -base64 32`
# AUTH_SECRET=
# Production canonical URL (used for OAuth callback URLs behind a proxy):
# AUTH_URL="https://your-domain.example"

# Optional — GitHub OAuth. When both are set, a "Continue with GitHub" button
# appears and the GitHub provider is enabled. Create an OAuth app at
# https://github.com/settings/developers (callback: <AUTH_URL>/api/auth/callback/github).
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# ── Ingestion pipeline (scripts/ingest-film.ts) ──────────────────────────────
# Optional. When set, the pipeline writes ORIGINAL summary/context/interpretation
# via the Anthropic API; when unset, films are ingested as drafts with
# placeholder text for manual authoring.
# ANTHROPIC_API_KEY=
